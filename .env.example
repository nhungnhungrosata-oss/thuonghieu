# Bắt buộc: token UseAPI, giữ nguyên tiền tố user:
USEAPI_TOKEN=user:xxxxxxxxxxxxxxxxxxxxxxxx

# Khuyến nghị: Gmail Flow đã add vào useapi.net.
# Nếu bỏ trống, UseAPI sẽ tự load-balance tài khoản phù hợp khi có nhiều account.
USEAPI_EMAIL=your-flow-account@gmail.com

# Model mặc định. Gợi ý tiết kiệm: veo-3.1-lite
# Ultra $199 có thể dùng: veo-3.1-lite-low-priority
USEAPI_MODEL=veo-3.1-lite
